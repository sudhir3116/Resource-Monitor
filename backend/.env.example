MONGO_URI=mongodb+srv://<user>:<pass>@cluster0.mongodb.net/dbname
JWT_SECRET=your_jwt_secret_here
GOOGLE_CLIENT_ID=your_google_client_id_here

# Mailer (use Mailtrap for development)
# Sign up at https://mailtrap.io and use the SMTP credentials they provide
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass
FROM_EMAIL="Sustainable Monitor <no-reply@example.com>"

PORT=4000
